<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>NexaStudio — Web Agency</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: { extend: { fontFamily: { sans: ['Inter', 'sans-serif'] } } }
    }
  </script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/style.css">
</head>
<body class="font-sans bg-white text-gray-900 antialiased">

<%- include('partials/navbar') %>

<!-- ── HERO ─────────────────────────────────────────── -->
<section class="relative min-h-screen flex items-center pt-16 overflow-hidden">
  <!-- Color blobs -->
  <div class="blob" style="width:600px;height:600px;top:-150px;right:-150px;background:#a78bfa;opacity:0.18;"></div>
  <div class="blob" style="width:350px;height:350px;bottom:0;left:-80px;background:#60a5fa;opacity:0.15;"></div>
  <div class="blob" style="width:280px;height:280px;top:250px;left:38%;background:#34d399;opacity:0.12;"></div>

  <div class="max-w-7xl mx-auto px-6 py-28 grid md:grid-cols-2 gap-16 items-center relative z-10">

    <!-- Left -->
    <div class="fade-up">
      <div class="inline-flex items-center gap-2 bg-violet-50 border border-violet-100 text-violet-700 text-xs font-semibold px-3 py-1.5 rounded-full mb-6">
        <span class="w-1.5 h-1.5 bg-violet-500 rounded-full animate-pulse"></span>
        Now accepting new clients
      </div>

      <h1 class="text-5xl md:text-6xl lg:text-7xl font-black leading-[1.05] tracking-tight text-gray-900 mb-6">
        Elevate your<br>
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-violet-600 to-indigo-500">Brand, Design</span><br>
        and Success.
      </h1>

      <p class="text-lg text-gray-500 leading-relaxed mb-8 max-w-md">
        We craft stunning digital experiences that turn visitors into loyal customers — from strategy to launch and beyond.
      </p>

      <div class="flex items-center gap-4 flex-wrap">
        <a href="/contact" class="bg-violet-600 hover:bg-violet-700 text-white font-semibold px-7 py-3.5 rounded-full transition-all hover:shadow-xl hover:shadow-violet-200 hover:-translate-y-0.5">
          Start a Project →
        </a>
        <a href="/services" class="text-gray-700 font-semibold px-7 py-3.5 rounded-full border border-gray-200 hover:border-violet-300 hover:text-violet-600 transition-all">
          Our Services
        </a>
      </div>

      <!-- Social proof -->
      <div class="flex items-center gap-8 mt-12 pt-8 border-t border-gray-100">
        <div>
          <p class="text-2xl font-black text-gray-900">200+</p>
          <p class="text-xs text-gray-400 mt-0.5">Projects delivered</p>
        </div>
        <div class="w-px h-10 bg-gray-200"></div>
        <div>
          <p class="text-2xl font-black text-gray-900">98%</p>
          <p class="text-xs text-gray-400 mt-0.5">Client satisfaction</p>
        </div>
        <div class="w-px h-10 bg-gray-200"></div>
        <div>
          <p class="text-2xl font-black text-gray-900">5y+</p>
          <p class="text-xs text-gray-400 mt-0.5">In the industry</p>
        </div>
      </div>
    </div>

    <!-- Right – floating UI card -->
    <div class="hidden md:block relative">
      <div class="bg-white rounded-3xl shadow-2xl shadow-gray-200/80 border border-gray-100 p-6">
        <!-- Window dots -->
        <div class="flex items-center gap-1.5 mb-5">
          <div class="w-3 h-3 rounded-full bg-red-400"></div>
          <div class="w-3 h-3 rounded-full bg-yellow-400"></div>
          <div class="w-3 h-3 rounded-full bg-green-400"></div>
          <p class="ml-3 text-xs text-gray-400 font-medium">What can we help you with?</p>
        </div>
        <!-- Service grid -->
        <div class="grid grid-cols-2 gap-3 mb-3">
          <div class="bg-gray-50 hover:bg-violet-50 rounded-2xl p-4 flex items-center gap-3 cursor-pointer transition-colors">
            <div class="w-10 h-10 bg-violet-100 rounded-xl flex items-center justify-center text-xl flex-shrink-0">🎨</div>
            <div>
              <p class="text-sm font-semibold text-gray-800">Web Design</p>
              <p class="text-xs text-gray-400">UI / UX</p>
            </div>
          </div>
          <div class="bg-gray-50 hover:bg-blue-50 rounded-2xl p-4 flex items-center gap-3 cursor-pointer transition-colors">
            <div class="w-10 h-10 bg-blue-100 rounded-xl flex items-center justify-center text-xl flex-shrink-0">💻</div>
            <div>
              <p class="text-sm font-semibold text-gray-800">Development</p>
              <p class="text-xs text-gray-400">Front & Back</p>
            </div>
          </div>
          <div class="bg-gray-50 hover:bg-green-50 rounded-2xl p-4 flex items-center gap-3 cursor-pointer transition-colors">
            <div class="w-10 h-10 bg-green-100 rounded-xl flex items-center justify-center text-xl flex-shrink-0">📈</div>
            <div>
              <p class="text-sm font-semibold text-gray-800">SEO & Growth</p>
              <p class="text-xs text-gray-400">Analytics</p>
            </div>
          </div>
          <div class="bg-gray-50 hover:bg-orange-50 rounded-2xl p-4 flex items-center gap-3 cursor-pointer transition-colors">
            <div class="w-10 h-10 bg-orange-100 rounded-xl flex items-center justify-center text-xl flex-shrink-0">📱</div>
            <div>
              <p class="text-sm font-semibold text-gray-800">Mobile Apps</p>
              <p class="text-xs text-gray-400">iOS & Android</p>
            </div>
          </div>
        </div>
        <div class="p-4 bg-gradient-to-r from-violet-600 to-indigo-600 rounded-2xl text-white text-center">
          <p class="text-sm font-semibold">Free consultation available</p>
          <p class="text-xs text-violet-200 mt-0.5">Mon–Fri · 9:00 – 17:00</p>
        </div>
      </div>

      <!-- Floating badge -->
      <div class="absolute -top-4 -right-4 bg-white border border-gray-100 shadow-lg rounded-2xl px-4 py-2.5 flex items-center gap-2">
        <span class="text-green-500 text-lg">✅</span>
        <div>
          <p class="text-xs font-bold text-gray-800">Project delivered</p>
          <p class="text-xs text-gray-400">2 days early</p>
        </div>
      </div>
    </div>

  </div>
</section>

<!-- ── VALUE STRIP ───────────────────────────────────── -->
<section class="py-16 bg-gray-50 border-y border-gray-100">
  <div class="max-w-7xl mx-auto px-6 grid md:grid-cols-3 gap-8">
    <div class="flex items-start gap-4">
      <div class="w-11 h-11 bg-violet-100 rounded-xl flex items-center justify-center text-2xl flex-shrink-0">⚡</div>
      <div>
        <h3 class="font-bold text-gray-900 mb-1">Lightning Fast</h3>
        <p class="text-sm text-gray-500">Optimized for Core Web Vitals and peak performance from day one.</p>
      </div>
    </div>
    <div class="flex items-start gap-4">
      <div class="w-11 h-11 bg-blue-100 rounded-xl flex items-center justify-center text-2xl flex-shrink-0">🎯</div>
      <div>
        <h3 class="font-bold text-gray-900 mb-1">Results Driven</h3>
        <p class="text-sm text-gray-500">Every decision backed by data, conversion goals, and business KPIs.</p>
      </div>
    </div>
    <div class="flex items-start gap-4">
      <div class="w-11 h-11 bg-green-100 rounded-xl flex items-center justify-center text-2xl flex-shrink-0">🛡️</div>
      <div>
        <h3 class="font-bold text-gray-900 mb-1">Fully Reliable</h3>
        <p class="text-sm text-gray-500">99.9% uptime guarantee with continuous monitoring and support.</p>
      </div>
    </div>
  </div>
</section>

<!-- ── OUR PROCESS ───────────────────────────────────── -->
<section class="py-28">
  <div class="max-w-7xl mx-auto px-6">
    <div class="text-center mb-16">
      <p class="text-violet-600 font-semibold text-xs uppercase tracking-widest mb-3">Our Approach</p>
      <h2 class="text-4xl md:text-5xl font-black text-gray-900">Lead your digital<br>transformation</h2>
    </div>

    <div class="grid md:grid-cols-2 gap-16 items-center">
      <!-- Steps -->
      <div class="space-y-7">
        <div class="flex items-start gap-4">
          <div class="w-9 h-9 bg-violet-600 rounded-full flex items-center justify-center text-white text-sm font-bold flex-shrink-0 mt-0.5 shadow-lg shadow-violet-200">1</div>
          <div>
            <h4 class="font-bold text-gray-900 mb-1">Discovery & Strategy</h4>
            <p class="text-gray-500 text-sm leading-relaxed">We deeply understand your business, audience, and goals to craft the perfect digital roadmap.</p>
          </div>
        </div>
        <div class="flex items-start gap-4">
          <div class="w-9 h-9 bg-indigo-600 rounded-full flex items-center justify-center text-white text-sm font-bold flex-shrink-0 mt-0.5 shadow-lg shadow-indigo-200">2</div>
          <div>
            <h4 class="font-bold text-gray-900 mb-1">Design & Prototype</h4>
            <p class="text-gray-500 text-sm leading-relaxed">Our designers craft pixel-perfect mockups aligned with your brand and user needs.</p>
          </div>
        </div>
        <div class="flex items-start gap-4">
          <div class="w-9 h-9 bg-blue-600 rounded-full flex items-center justify-center text-white text-sm font-bold flex-shrink-0 mt-0.5 shadow-lg shadow-blue-200">3</div>
          <div>
            <h4 class="font-bold text-gray-900 mb-1">Build & Launch</h4>
            <p class="text-gray-500 text-sm leading-relaxed">We develop with modern technologies and deploy with zero downtime.</p>
          </div>
        </div>
        <div class="flex items-start gap-4">
          <div class="w-9 h-9 bg-violet-400 rounded-full flex items-center justify-center text-white text-sm font-bold flex-shrink-0 mt-0.5 shadow-lg shadow-violet-100">4</div>
          <div>
            <h4 class="font-bold text-gray-900 mb-1">Grow & Optimize</h4>
            <p class="text-gray-500 text-sm leading-relaxed">We monitor analytics and continuously improve your presence post-launch.</p>
          </div>
        </div>
      </div>

      <!-- Task tracker card -->
      <div class="bg-gradient-to-br from-violet-50 to-indigo-50 rounded-3xl p-8 border border-violet-100">
        <p class="text-xs font-semibold text-violet-500 uppercase tracking-widest mb-4">Project Dashboard</p>
        <div class="space-y-3">
          <div class="bg-white rounded-2xl p-4 shadow-sm flex items-center gap-4">
            <div class="w-10 h-10 bg-green-100 rounded-xl flex items-center justify-center text-xl flex-shrink-0">✅</div>
            <div class="flex-1 min-w-0">
              <p class="font-semibold text-gray-800 text-sm">Homepage redesign</p>
              <p class="text-xs text-gray-400">Delivered in 7 days</p>
            </div>
            <span class="text-xs bg-green-100 text-green-700 px-2.5 py-1 rounded-full font-semibold whitespace-nowrap">Done</span>
          </div>
          <div class="bg-white rounded-2xl p-4 shadow-sm flex items-center gap-4">
            <div class="w-10 h-10 bg-blue-100 rounded-xl flex items-center justify-center text-xl flex-shrink-0">⚙️</div>
            <div class="flex-1 min-w-0">
              <p class="font-semibold text-gray-800 text-sm">Backend integration</p>
              <p class="text-xs text-gray-400">In progress · 80%</p>
            </div>
            <span class="text-xs bg-blue-100 text-blue-700 px-2.5 py-1 rounded-full font-semibold whitespace-nowrap">Active</span>
          </div>
          <div class="bg-white rounded-2xl p-4 shadow-sm flex items-center gap-4">
            <div class="w-10 h-10 bg-violet-100 rounded-xl flex items-center justify-center text-xl flex-shrink-0">📊</div>
            <div class="flex-1 min-w-0">
              <p class="font-semibold text-gray-800 text-sm">SEO optimization</p>
              <p class="text-xs text-gray-400">Next sprint</p>
            </div>
            <span class="text-xs bg-violet-100 text-violet-700 px-2.5 py-1 rounded-full font-semibold whitespace-nowrap">Queued</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ── STATS ─────────────────────────────────────────── -->
<section class="py-28 bg-gray-950 relative overflow-hidden">
  <div class="blob" style="width:500px;height:500px;top:-150px;left:-100px;background:#7c3aed;opacity:0.12;"></div>
  <div class="blob" style="width:400px;height:400px;bottom:-100px;right:-80px;background:#4f46e5;opacity:0.1;"></div>

  <div class="max-w-7xl mx-auto px-6 relative z-10">
    <p class="text-center text-gray-500 text-xs font-semibold uppercase tracking-widest mb-3">Our Numbers</p>
    <h2 class="text-4xl md:text-5xl font-black text-white text-center mb-16">Reliable, Proven,<br>and Trusted</h2>

    <div class="grid md:grid-cols-3 gap-6">
      <div class="bg-white/5 border border-white/10 rounded-3xl p-10 text-center hover:bg-white/8 transition-colors">
        <p class="text-6xl font-black text-white mb-2">99%</p>
        <p class="text-gray-400 text-sm">Client Satisfaction Rate</p>
      </div>
      <div class="bg-white/5 border border-white/10 rounded-3xl p-10 text-center hover:bg-white/8 transition-colors">
        <p class="text-6xl font-black text-white mb-2">200+</p>
        <p class="text-gray-400 text-sm">Projects Delivered</p>
      </div>
      <div class="bg-white/5 border border-white/10 rounded-3xl p-10 text-center hover:bg-white/8 transition-colors">
        <p class="text-6xl font-black text-white mb-2">95%</p>
        <p class="text-gray-400 text-sm">On-time Delivery</p>
      </div>
    </div>
  </div>
</section>

<!-- ── CTA ───────────────────────────────────────────── -->
<section class="py-28 bg-gradient-to-br from-violet-600 to-indigo-700 relative overflow-hidden">
  <div class="blob" style="width:500px;height:500px;top:-100px;right:-100px;background:#fff;opacity:0.04;"></div>
  <div class="max-w-3xl mx-auto px-6 text-center relative z-10">
    <h2 class="text-4xl md:text-5xl font-black text-white mb-4">Ready to build something great?</h2>
    <p class="text-violet-200 text-lg mb-10">Let's talk about your project. We're here Mon–Fri, 9:00–17:00.</p>
    <a href="/contact" class="inline-block bg-white text-violet-700 font-bold px-10 py-4 rounded-full hover:shadow-2xl transition-all hover:-translate-y-0.5">
      Start your project →
    </a>
  </div>
</section>

<%- include('partials/footer') %>
</body>
</html>
