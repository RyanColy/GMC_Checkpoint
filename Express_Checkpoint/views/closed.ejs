<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>We're Closed — NexaStudio</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: { extend: { fontFamily: { sans: ['Inter', 'sans-serif'] } } }
    }
  </script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/style.css">
</head>
<body class="font-sans bg-gray-950 text-white antialiased min-h-screen flex flex-col items-center justify-center relative overflow-hidden">

  <!-- Background blobs -->
  <div class="blob" style="width:500px;height:500px;top:-100px;left:-100px;background:#7c3aed;opacity:0.15;"></div>
  <div class="blob" style="width:400px;height:400px;bottom:-100px;right:-100px;background:#4f46e5;opacity:0.1;"></div>

  <div class="relative z-10 text-center px-6 max-w-lg">

    <!-- Icon -->
    <div class="w-20 h-20 bg-white/10 border border-white/20 rounded-3xl flex items-center justify-center text-4xl mx-auto mb-8">🔒</div>

    <!-- Logo -->
    <div class="flex items-center justify-center gap-2 mb-10">
      <div class="w-7 h-7 bg-violet-600 rounded-lg flex items-center justify-center">
        <svg class="w-3.5 h-3.5 text-white" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"/>
        </svg>
      </div>
      <span class="font-black text-white text-lg tracking-tight">Nexa<span class="text-violet-400">Studio</span></span>
    </div>

    <h1 class="text-4xl md:text-5xl font-black mb-4 leading-tight">
      We're currently<br>
      <span class="text-transparent bg-clip-text bg-gradient-to-r from-violet-400 to-indigo-400">closed</span>
    </h1>

    <p class="text-gray-400 text-lg mb-8">
      Today is <strong class="text-white"><%= day %></strong> and the current time is <strong class="text-white"><%= time %></strong>.
    </p>

    <!-- Hours card -->
    <div class="bg-white/5 border border-white/10 rounded-3xl p-6 mb-8">
      <p class="text-xs font-semibold text-gray-400 uppercase tracking-widest mb-4">Business Hours</p>
      <div class="grid grid-cols-2 gap-3 text-sm">
        <div class="bg-white/5 rounded-xl p-3">
          <p class="text-gray-400 text-xs mb-1">Days</p>
          <p class="font-semibold text-white">Monday – Friday</p>
        </div>
        <div class="bg-white/5 rounded-xl p-3">
          <p class="text-gray-400 text-xs mb-1">Hours</p>
          <p class="font-semibold text-white">9:00 AM – 5:00 PM</p>
        </div>
      </div>
    </div>

    <p class="text-gray-500 text-sm">
      You can still reach us by email at<br>
      <a href="mailto:hello@nexastudio.io" class="text-violet-400 hover:text-violet-300 font-semibold transition-colors">hello@nexastudio.io</a>
    </p>
  </div>

</body>
</html>
