<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Contact us — NexaStudio</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: { extend: { fontFamily: { sans: ['Inter', 'sans-serif'] } } }
    }
  </script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/style.css">
</head>
<body class="font-sans bg-white text-gray-900 antialiased">

<%- include('partials/navbar') %>

<!-- ── PAGE HERO ─────────────────────────────────────── -->
<section class="relative pt-32 pb-16 overflow-hidden">
  <div class="blob" style="width:450px;height:450px;top:-100px;right:-100px;background:#a78bfa;opacity:0.15;"></div>
  <div class="max-w-3xl mx-auto px-6 text-center relative z-10">
    <div class="inline-flex items-center gap-2 bg-violet-50 border border-violet-100 text-violet-700 text-xs font-semibold px-3 py-1.5 rounded-full mb-6">
      <span class="w-1.5 h-1.5 bg-green-500 rounded-full animate-pulse"></span>
      Available Mon–Fri · 9:00–17:00
    </div>
    <h1 class="text-5xl md:text-6xl font-black leading-tight tracking-tight text-gray-900 mb-4">
      Let's Work <span class="text-transparent bg-clip-text bg-gradient-to-r from-violet-600 to-indigo-500">Together</span>
    </h1>
    <p class="text-lg text-gray-500">
      Tell us about your project and we'll get back to you within 24 hours.
    </p>
  </div>
</section>

<!-- ── CONTACT CONTENT ───────────────────────────────── -->
<section class="pb-28">
  <div class="max-w-7xl mx-auto px-6 grid md:grid-cols-3 gap-12">

    <!-- Info sidebar -->
    <div class="space-y-6">
      <div class="bg-gray-50 rounded-3xl p-6 border border-gray-100">
        <div class="w-11 h-11 bg-violet-100 rounded-xl flex items-center justify-center text-xl mb-4">📍</div>
        <h4 class="font-bold text-gray-900 mb-1">Our Office</h4>
        <p class="text-sm text-gray-500">12 Avenue Habib Bourguiba<br>Tunis, Tunisia</p>
      </div>

      <div class="bg-gray-50 rounded-3xl p-6 border border-gray-100">
        <div class="w-11 h-11 bg-blue-100 rounded-xl flex items-center justify-center text-xl mb-4">📧</div>
        <h4 class="font-bold text-gray-900 mb-1">Email us</h4>
        <p class="text-sm text-gray-500">hello@nexastudio.io<br>support@nexastudio.io</p>
      </div>

      <div class="bg-gray-50 rounded-3xl p-6 border border-gray-100">
        <div class="w-11 h-11 bg-green-100 rounded-xl flex items-center justify-center text-xl mb-4">🕐</div>
        <h4 class="font-bold text-gray-900 mb-1">Working Hours</h4>
        <p class="text-sm text-gray-500">Monday to Friday<br>9:00 AM – 5:00 PM</p>
      </div>
    </div>

    <!-- Form -->
    <div class="md:col-span-2">

      <% if (success) { %>
      <div class="bg-green-50 border border-green-200 rounded-3xl p-8 text-center mb-8">
        <div class="text-5xl mb-4">🎉</div>
        <h3 class="text-xl font-bold text-green-800 mb-2">Message sent successfully!</h3>
        <p class="text-green-600 text-sm">We'll get back to you within 24 hours.</p>
      </div>
      <% } %>

      <form method="POST" action="/contact" class="bg-white border border-gray-100 rounded-3xl p-8 shadow-sm space-y-5">
        <div class="grid md:grid-cols-2 gap-5">
          <div>
            <label class="block text-sm font-semibold text-gray-700 mb-2">Full Name</label>
            <input
              type="text"
              name="name"
              required
              placeholder="John Doe"
              class="w-full border border-gray-200 rounded-xl px-4 py-3 text-sm text-gray-900 placeholder-gray-400 transition-all"
            />
          </div>
          <div>
            <label class="block text-sm font-semibold text-gray-700 mb-2">Email Address</label>
            <input
              type="email"
              name="email"
              required
              placeholder="john@company.com"
              class="w-full border border-gray-200 rounded-xl px-4 py-3 text-sm text-gray-900 placeholder-gray-400 transition-all"
            />
          </div>
        </div>

        <div>
          <label class="block text-sm font-semibold text-gray-700 mb-2">Service Needed</label>
          <select
            name="service"
            class="w-full border border-gray-200 rounded-xl px-4 py-3 text-sm text-gray-900 transition-all bg-white"
          >
            <option value="">Select a service…</option>
            <option>Web Design</option>
            <option>Web Development</option>
            <option>SEO & Analytics</option>
            <option>Mobile Apps</option>
            <option>Branding & Identity</option>
            <option>Custom Solution</option>
          </select>
        </div>

        <div>
          <label class="block text-sm font-semibold text-gray-700 mb-2">Budget Range</label>
          <select
            name="budget"
            class="w-full border border-gray-200 rounded-xl px-4 py-3 text-sm text-gray-900 transition-all bg-white"
          >
            <option value="">Select a budget…</option>
            <option>Less than $1,000</option>
            <option>$1,000 – $5,000</option>
            <option>$5,000 – $15,000</option>
            <option>$15,000+</option>
          </select>
        </div>

        <div>
          <label class="block text-sm font-semibold text-gray-700 mb-2">Tell us about your project</label>
          <textarea
            name="message"
            required
            rows="5"
            placeholder="Describe your project, goals, and timeline…"
            class="w-full border border-gray-200 rounded-xl px-4 py-3 text-sm text-gray-900 placeholder-gray-400 transition-all resize-none"
          ></textarea>
        </div>

        <button
          type="submit"
          class="w-full bg-violet-600 hover:bg-violet-700 text-white font-bold py-4 rounded-full transition-all hover:shadow-xl hover:shadow-violet-200 hover:-translate-y-0.5"
        >
          Send Message →
        </button>

        <p class="text-xs text-gray-400 text-center">
          We respect your privacy. Your information is never shared.
        </p>
      </form>
    </div>

  </div>
</section>

<%- include('partials/footer') %>
</body>
</html>
